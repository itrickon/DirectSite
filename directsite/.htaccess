# Beget hosting configuration for Django
# Passenger WSGI Application

# Disable directory listing
Options -Indexes

# Set default charset
AddDefaultCharset utf-8

# Error pages
ErrorDocument 500 /500.html
ErrorDocument 404 /404.html

# Passenger configuration (если mod_passenger доступен)
<IfModule mod_passenger.c>
    PassengerEnabled On
    PassengerAppRoot /home/i/itrickon/itrickon.beget.tech/public_html
    PassengerAppType wsgi
    PassengerStartupFile passenger_wsgi.py
    # PassengerPython указывается в панели Beget
</IfModule>
