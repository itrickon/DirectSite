# Django на Timeweb (Passenger)
# Версия Python 3.4

# Устанавливаем версию Python
PassengerPythonApp /home/u/cc697629/directsite/passenger_wsgi.py
PassengerAppRoot /home/u/cc697629/directsite
PassengerEnabled On

# Логирование ошибок Passenger
PassengerLogUrl /home/u/cc697629/logs/passenger.log

# Статические файлы обрабатываются напрямую
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    
    # Пропускаем существующие файлы и директории
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
    
    # Все остальные запросы направляем на Django
    RewriteRule ^(.*)$ passenger_wsgi.py/$1 [QSA,L]
</IfModule>

# Заголовки безопасности
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>
